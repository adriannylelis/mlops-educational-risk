# Configurações para Deploy GCP
# Copie este arquivo para .env e preencha com seus valores

# Obrigatório: ID do projeto GCP
# Obter com: gcloud projects list
PROJECT_ID=

# Opcional: Região do GCP (padrão: us-central1)
REGION=us-central1

# Opcional: Nome do repositório no Artifact Registry (padrão: mlops-risk)
REPOSITORY=mlops-risk

# Opcional: Nome da imagem Docker (padrão: risk-api)
IMAGE_NAME=risk-api

# Opcional: Tag da imagem (padrão: latest)
IMAGE_TAG=latest

# Opcional: Nome do serviço no Cloud Run (padrão: risk-api)
SERVICE_NAME=risk-api

# Opcional: Recursos do Cloud Run
MEMORY=512Mi
CPU=1
MAX_INSTANCES=10
MIN_INSTANCES=0
TIMEOUT=300

# Exemplo de uso:
# 1. Copiar este arquivo: cp .env.example .env
# 2. Editar .env e preencher PROJECT_ID
# 3. Carregar variáveis: source .env
# 4. Deploy: ./scripts/deploy_cloud_run.sh
